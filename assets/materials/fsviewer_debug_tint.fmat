material {
  name: "FSViewerDebugTint",
  shading_model: unlit,
  blending: opaque,
  culling: back,
  parameters: [
    { type: vec4, name: tint, hint: source_color, default: [0.15, 0.65, 1.0, 1.0] },
    { type: float, name: strength, hint: range(0, 1, 0.01), default: 1.0 },
  ],
}

fragment {
  void Surface(inout MaterialInputs material) {
    material.base_color = vec4(material_params.tint.rgb * material_params.strength, material_params.tint.a);
  }
}
