final class _RuntimePrimitive {
  const _RuntimePrimitive({
    required this.address,
    required this.material,
  });

  final PartAddress address;
  final Object material;
}

List<_RuntimePrimitive> _runtimePrimitives(dynamic root) {
  if (root == null) {
    throw StateError('Runtime scene root is unavailable.');
  }
  final result = <_RuntimePrimitive>[];
  void visit(dynamic node, List<String> parentPath) {
    final name = node.name as String;
    final nodePath = <String>[...parentPath, name];
    final dynamic mesh = node.mesh;
    if (mesh != null) {
      final primitives = (mesh.primitives as Iterable).toList(growable: false);
      for (var index = 0; index < primitives.length; index += 1) {
        final dynamic primitive = primitives[index];
        result.add(
          _RuntimePrimitive(
            address: PartAddress(
              nodePath: nodePath,
              primitiveIndex: index,
            ),
            material: primitive.material as Object,
          ),
        );
      }
    }
    for (final dynamic child in node.children as Iterable) {
      visit(child, nodePath);
    }
  }

  visit(root, const <String>[]);
  return List<_RuntimePrimitive>.unmodifiable(result);
}

final class _GlbDocument {
  const _GlbDocument(this.json);

  final Map<String, Object?> json;

  factory _GlbDocument.fromBytes(Uint8List bytes) {
    if (bytes.lengthInBytes < 20) {
      throw StateError('GLB is too short for dependency inventory.');
    }
    final data = ByteData.sublistView(bytes);
    if (data.getUint32(0, Endian.little) != 0x46546c67 ||
        data.getUint32(4, Endian.little) != 2) {
      throw StateError('Dependency inventory requires a GLB 2 container.');
    }
    var offset = 12;
    while (offset + 8 <= bytes.lengthInBytes) {
      final length = data.getUint32(offset, Endian.little);
      final type = data.getUint32(offset + 4, Endian.little);
      offset += 8;
      if (offset + length > bytes.lengthInBytes) {
        throw StateError('GLB dependency inventory chunk is truncated.');
      }
      if (type == 0x4e4f534a) {
        final decoded = jsonDecode(
          utf8.decode(bytes.sublist(offset, offset + length)).trimRight(),
        );
        if (decoded is! Map) {
          throw StateError('GLB JSON chunk is not an object.');
        }
        return _GlbDocument(Map<String, Object?>.from(decoded));
      }
      offset += length;
    }
    throw StateError('GLB JSON chunk was not found.');
  }

  List<int> authoredMaterialIndices(String extension) {
    final materials =
        (json['materials'] as List<Object?>?) ?? const <Object?>[];
    return <int>[
      for (var index = 0; index < materials.length; index += 1)
        if (_materialExtensions(index).contains(extension)) index,
    ];
  }

  Map<String, List<int>> authoredDependencyInventory() =>
      _extensionInventory(const <int>[], defaultSceneOnly: false);

  Map<String, List<int>> defaultSceneInventory() {
    final used = <int>{};
    final scenes = (json['scenes'] as List<Object?>?) ?? const <Object?>[];
    if (scenes.isEmpty) {
      return _extensionInventory(const <int>[], defaultSceneOnly: true);
    }
    final sceneIndex = (json['scene'] as int?) ?? 0;
    if (sceneIndex < 0 || sceneIndex >= scenes.length) {
      throw StateError('Default scene index is outside the GLB scene list.');
    }
    final scene = Map<String, Object?>.from(scenes[sceneIndex]! as Map);
    final roots = (scene['nodes'] as List<Object?>?) ?? const <Object?>[];
    for (final root in roots.cast<int>()) {
      _collectNodeMaterials(root, used, <int>{});
    }
    return _extensionInventory(used.toList()..sort(), defaultSceneOnly: true);
  }

  Map<String, List<int>> _extensionInventory(
    List<int> used, {
    required bool defaultSceneOnly,
  }) {
    const extensions = <String>[
      'KHR_materials_sheen',
      'KHR_materials_clearcoat',
      'KHR_materials_transmission',
      'KHR_materials_volume',
      'KHR_materials_ior',
      'KHR_materials_specular',
    ];
    final indices = defaultSceneOnly
        ? used
        : List<int>.generate(
            (json['materials'] as List<Object?>?)?.length ?? 0,
            (index) => index,
          );
    return <String, List<int>>{
      for (final extension in extensions)
        extension: <int>[
          for (final index in indices)
            if (_materialExtensions(index).contains(extension)) index,
        ],
    };
  }

  Set<String> _materialExtensions(int materialIndex) {
    final materials =
        (json['materials'] as List<Object?>?) ?? const <Object?>[];
    if (materialIndex < 0 || materialIndex >= materials.length) {
      return const <String>{};
    }
    final material =
        Map<String, Object?>.from(materials[materialIndex]! as Map);
    final raw = material['extensions'];
    if (raw is! Map) {
      return const <String>{};
    }
    return Set<String>.from(raw.keys.cast<String>());
  }

  void _collectNodeMaterials(
    int nodeIndex,
    Set<int> materialIndices,
    Set<int> stack,
  ) {
    final nodes = (json['nodes'] as List<Object?>?) ?? const <Object?>[];
    if (nodeIndex < 0 || nodeIndex >= nodes.length || !stack.add(nodeIndex)) {
      return;
    }
    final node = Map<String, Object?>.from(nodes[nodeIndex]! as Map);
    final meshIndex = node['mesh'];
    if (meshIndex is int) {
      final meshes = (json['meshes'] as List<Object?>?) ?? const <Object?>[];
      if (meshIndex >= 0 && meshIndex < meshes.length) {
        final mesh = Map<String, Object?>.from(meshes[meshIndex]! as Map);
        final primitives =
            (mesh['primitives'] as List<Object?>?) ?? const <Object?>[];
        for (final rawPrimitive in primitives) {
          final primitive = Map<String, Object?>.from(rawPrimitive! as Map);
          final material = primitive['material'];
          if (material is int) {
            materialIndices.add(material);
          }
        }
      }
    }
    final children = (node['children'] as List<Object?>?) ?? const <Object?>[];
    for (final child in children.cast<int>()) {
      _collectNodeMaterials(child, materialIndices, stack);
    }
    stack.remove(nodeIndex);
  }
}

Future<Uint8List> _loadAssetBytes(String path) async {
  final data = await rootBundle.load(path);
  return data.buffer.asUint8List(data.offsetInBytes, data.lengthInBytes);
}

void _requireHash(String label, Uint8List bytes, String expected) {
  final actual = sha256.convert(bytes).toString();
  if (actual != expected) {
    throw StateError('$label SHA-256 mismatch: $actual != $expected');
  }
}

void _assertFixedState(Map<String, Object?> state) {
  final identity = (
    state['name'],
    state['comparisonBoundary'],
  );
  if (identity !=
          (
            'plan018_khr_materials_sheen_controlled_comparison',
            'direction/conformance-only',
          ) &&
      identity !=
          (
            'plan018_renderer_native_scalar_sheen_control',
            'renderer-local sheen on/off control only',
          )) {
    throw StateError('Plan 018 controlled state identity drifted.');
  }
  if (state['toneMapping'] != 'pbrNeutral' ||
      state['outputColorSpace'] != 'sRGB') {
    throw StateError('Plan 018 controlled output contract drifted.');
  }
  final passes = (state['renderPasses']! as List<Object?>).cast<String>();
  if (!_sameStrings(
    passes,
    const <String>['directOnly', 'iblOnly', 'combined'],
  )) {
    throw StateError('Plan 018 render passes drifted.');
  }
  final viewport = Map<String, Object?>.from(state['viewport']! as Map);
  if (viewport['logicalWidth'] != 402 ||
      viewport['logicalHeight'] != 874 ||
      viewport['devicePixelRatio'] != 3) {
    throw StateError('Plan 018 viewport drifted.');
  }
  final camera = Map<String, Object?>.from(state['camera']! as Map);
  if (camera['verticalFovDegrees'] != 60.0 ||
      camera['near'] != 0.1 ||
      camera['far'] != 1000.0 ||
      !_nearLists(
        _doubleList(camera['up']! as List<Object?>),
        const <double>[0, 1, 0],
      )) {
    throw StateError('Plan 018 camera projection contract drifted.');
  }
  final environment = Map<String, Object?>.from(state['environment']! as Map);
  if (environment['showSkybox'] != false ||
      environment['intensity'] != 1.0 ||
      environment['rotationRadians'] != 0.0) {
    throw StateError('Plan 018 environment contract drifted.');
  }
  final lighting = Map<String, Object?>.from(state['lighting']! as Map);
  if (lighting['exposure'] != 1.0 ||
      lighting['ambientOcclusion'] != false ||
      lighting['keyLightIntensity'] != 3.0 ||
      lighting['keyLightCastsShadow'] != false) {
    throw StateError('Plan 018 lighting contract drifted.');
  }
}

void _requireInstalledTexture(String label, Object? source, bool expected) {
  if ((source != null) != expected) {
    throw StateError('$label texture presence drifted.');
  }
  if (expected && !_sampledTextureAvailable(source)) {
    throw StateError('$label texture is not GPU-backed.');
  }
}

bool _sampledTextureAvailable(Object? source) {
  if (source == null) {
    return false;
  }
  final dynamic inferredSource = source;
  return inferredSource.sampledTexture != null;
}

bool _isIdentityTransform(TextureTransform transform) =>
    transform.offsetX == 0 &&
    transform.offsetY == 0 &&
    transform.scaleX == 1 &&
    transform.scaleY == 1 &&
    transform.rotation == 0;

void _requireTransform(
  String label,
  TextureTransform actual,
  TextureTransform expected,
) {
  if (!_near(actual.offsetX, expected.offsetX) ||
      !_near(actual.offsetY, expected.offsetY) ||
      !_near(actual.scaleX, expected.scaleX) ||
      !_near(actual.scaleY, expected.scaleY) ||
      !_near(actual.rotation, expected.rotation) ||
      actual.texCoordOverride != expected.texCoordOverride) {
    throw StateError('$label texture transform drifted.');
  }
}

void _requireNativeTransform(
  String label,
  Object actual,
  TextureTransform expected,
) {
  final values = _nativeTransformJson(actual);
  if (!_near(values['offsetX']! as double, expected.offsetX) ||
      !_near(values['offsetY']! as double, expected.offsetY) ||
      !_near(values['scaleX']! as double, expected.scaleX) ||
      !_near(values['scaleY']! as double, expected.scaleY) ||
      !_near(values['rotation']! as double, expected.rotation)) {
    throw StateError('$label native texture transform drifted.');
  }
}

Map<String, Object?> _nativeTransformJson(Object value) {
  final dynamic transform = value;
  return <String, Object?>{
    'offsetX': (transform.offsetX as num).toDouble(),
    'offsetY': (transform.offsetY as num).toDouble(),
    'scaleX': (transform.scaleX as num).toDouble(),
    'scaleY': (transform.scaleY as num).toDouble(),
    'rotation': (transform.rotation as num).toDouble(),
  };
}

Color _colorFromHex(String value) {
  if (!RegExp(r'^#[0-9a-fA-F]{6}$').hasMatch(value)) {
    throw StateError('Background must be a six-digit sRGB hex color.');
  }
  return Color(0xff000000 | int.parse(value.substring(1), radix: 16));
}

List<double> _doubleList(List<Object?> values) => List<double>.unmodifiable(
    values.map((value) => (value! as num).toDouble()));

bool _near(double left, double right) => (left - right).abs() <= 1e-6;

bool _nearLists(List<double> left, List<double> right) {
  if (left.length != right.length) {
    return false;
  }
  for (var index = 0; index < left.length; index += 1) {
    if (!_near(left[index], right[index])) {
      return false;
    }
  }
  return true;
}

bool _sameStrings(List<String> left, List<String> right) {
  if (left.length != right.length) {
    return false;
  }
  for (var index = 0; index < left.length; index += 1) {
    if (left[index] != right[index]) {
      return false;
    }
  }
  return true;
}

bool _sameInts(List<int> left, List<int> right) {
  if (left.length != right.length) {
    return false;
  }
  for (var index = 0; index < left.length; index += 1) {
    if (left[index] != right[index]) {
      return false;
    }
  }
  return true;
}

bool _sameAddresses(Set<PartAddress> left, Set<PartAddress> right) =>
    left.length == right.length && left.containsAll(right);
